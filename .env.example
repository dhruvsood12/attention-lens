# Backend
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info

# ML model paths (relative to repo root or absolute)
MODEL_TEXT_PATH=ml/saved_models/text_baseline.joblib
MODEL_IMAGE_PATH=ml/saved_models/image_baseline.joblib
MODEL_MULTIMODAL_PATH=ml/saved_models/multimodal_baseline.joblib

# Optional: use mock predictor until models are trained
USE_MOCK_PREDICTOR=true

# Frontend (Vite) - optional API URL override
# If omitted, frontend defaults to http://localhost:8000
VITE_API_BASE_URL=http://localhost:8000
